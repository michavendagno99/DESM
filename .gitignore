compile.log

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/

# ── OS / editor cruft ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/
.idea/

# ── Local scratch / temp outputs ────────────────────────────────────────
*.tmp
*.bak
~$*
